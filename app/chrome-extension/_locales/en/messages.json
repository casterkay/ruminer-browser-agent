  "welcomeTitle": {
    "message": "Ruminer Browser Agent",
    "description": "Welcome page title"
  },
  "welcomeSubtitle": {
    "message": "One browser, one memory, many agents. This page helps you wire up Ruminer across OpenClaw, Claude Code, Codex, and Hermes Agent for browser automation.",
    "description": "Welcome page subtitle"
  },
  "welcomeStepInstallTitle": {
    "message": "1) Run the Installation Command",
    "description": "Welcome install step title"
  },
  "welcomeStepInstallSubtitle": {
    "message": "This registers the native MCP server in Claude Code and Codex, configures Hermes Agent when its CLI is installed, and installs an OpenClaw plugin as MCP client.",
    "description": "Welcome install step subtitle"
  },
  "welcomeInstallTipPrefix": {
    "message": "Tip: you can review the script in your browser first.",
    "description": "Welcome install tip prefix"
  },
  "welcomeInstallTipSuffix": {
    "message": "is powerful - apply it with care.",
    "description": "Welcome install tip suffix"
  },
  "welcomeStepLanguageTitle": {
    "message": "2) Choose Interface Language",
    "description": "Welcome language step title"
  },
  "welcomeStepLanguageSubtitle": {
    "message": "Set your preferred language for Ruminer extension interfaces.",
    "description": "Welcome language step subtitle"
  },
  "welcomeStepGatewayTitle": {
    "message": "3) Configure OpenClaw Gateway",
    "description": "Welcome gateway step title"
  },
  "welcomeStepGatewaySubtitle": {
    "message": "If used as AI agent backend.",
    "description": "Welcome gateway step subtitle"
  },
  "welcomeStepMemoryTitle": {
    "message": "4) Configure Memory Store",
    "description": "Welcome memory step title"
