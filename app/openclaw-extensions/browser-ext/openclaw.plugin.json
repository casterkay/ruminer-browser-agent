{
  "id": "browser-ext",
  "name": "Ruminer Browser Extension Plugin",
  "version": "0.1.0",
  "extensions": ["./index.ts"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mcporterServer": {
        "type": "string",
        "description": "Optional mcporter server name to call (e.g., \"ruminer\"). If set, the plugin calls `mcporter call <server>.<tool>`."
      },
      "mcporterConfigPath": {
        "type": "string",
        "description": "Optional path to a mcporter config file (passed as `--config`)."
      },
      "mcporterCommand": {
        "type": "string",
        "description": "Optional mcporter executable name/path (default: \"mcporter\")."
      },
      "mcpUrl": {
        "type": "string",
        "default": "http://127.0.0.1:12306/mcp",
        "description": "Fallback MCP HTTP endpoint used when mcporterServer is not set."
      }
    }
  },
  "uiHints": {
    "mcpUrl": { "label": "Ruminer MCP URL", "placeholder": "http://127.0.0.1:12306/mcp" },
    "mcporterServer": { "label": "mcporter Server", "placeholder": "ruminer" },
    "mcporterConfigPath": {
      "label": "mcporter Config Path",
      "placeholder": "~/.mcporter/mcporter.json"
    },
    "mcporterCommand": { "label": "mcporter Command", "placeholder": "mcporter" }
  }
}
