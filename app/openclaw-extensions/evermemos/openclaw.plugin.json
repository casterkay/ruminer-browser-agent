{
  "id": "evermemos",
  "name": "EverMemOS Plugin",
  "version": "0.1.0",
  "extensions": ["./index.ts"],
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "evermemosBaseUrl": {
        "type": "string",
        "description": "EverMemOS base URL (e.g. http://localhost:1995)"
      },
      "apiKey": { "type": "string", "description": "EverMemOS API key (Bearer token)" },
      "tenantId": { "type": "string" },
      "spaceId": { "type": "string" },
      "defaultUserId": { "type": "string" },
      "groupMapping": {
        "type": "object",
        "additionalProperties": { "type": "string" },
        "description": "Map channelId/threadId to EverMemOS group_id"
      },
      "ingestGroupIdPrefix": { "type": "string", "default": "oc-" },
      "backlogWarning": { "type": "integer", "default": 100 }
    }
  },
  "uiHints": {
    "apiKey": { "sensitive": true, "label": "EverMemOS API Key" },
    "evermemosBaseUrl": { "label": "EverMemOS Base URL", "placeholder": "http://localhost:1995" }
  }
}
