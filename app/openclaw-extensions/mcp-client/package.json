{
  "name": "openclaw-mcp-plugin",
  "version": "0.2.1",
  "description": "MCP client plugin for OpenClaw (routes tool calls to a configurable Streamable HTTP MCP server)",
  "type": "module",
  "license": "MIT",
  "author": "poetrycoder",
  "keywords": [
    "openclaw",
    "mcp",
    "modelcontextprotocol",
    "plugin"
  ],
  "engines": {
    "node": ">=22.0.0"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./openclaw.plugin.json": "./openclaw.plugin.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/casterkay/openclaw-mcp-plugin.git"
  },
  "homepage": "https://github.com/casterkay/openclaw-mcp-plugin#readme",
  "bugs": {
    "url": "https://github.com/casterkay/openclaw-mcp-plugin/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup index.ts --format esm --dts --clean --external openclaw",
    "dev": "tsup index.ts --format esm --dts --watch --external openclaw",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "prepack": "node scripts/check-versions.js && npm run build",
    "pack": "pnpm pack",
    "pack:release": "pnpm pack --pack-destination ../../../releases",
    "publish:dry-run": "pnpm publish --dry-run --access public",
    "publish:latest": "pnpm publish --access public",
    "publish:beta": "pnpm publish --tag beta --access public"
  },
  "files": [
    "openclaw.plugin.json",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ]
  }
}
