{
  "id": "openclaw-mcp-plugin",
  "name": "MCP Client Plugin",
  "description": "Routes OpenClaw tool calls to a configurable MCP server URL.",
  "version": "0.2.1",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "mcpUrl": {
        "type": "string",
        "default": "http://127.0.0.1:12306/mcp",
        "description": "MCP server endpoint (Streamable HTTP preferred)."
      },
      "transport": {
        "type": "string",
        "default": "auto",
        "enum": ["auto", "streamable-http", "sse"],
        "description": "Transport preference. 'auto' tries Streamable HTTP first, then falls back to deprecated SSE."
      },
      "clientName": {
        "type": "string",
        "description": "Optional MCP client name shown to the MCP server (for diagnostics)."
      }
    }
  },
  "uiHints": {
    "mcpUrl": { "label": "MCP Server URL", "placeholder": "http://127.0.0.1:12306/mcp" },
    "transport": { "label": "Transport", "placeholder": "auto" },
    "clientName": { "label": "Client Name", "placeholder": "openclaw-mcp-plugin" }
  }
}
