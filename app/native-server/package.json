{
  "name": "mcp-chrome-bridge",
  "version": "1.0.29",
  "description": "Native Messaging host + local MCP server for Ruminer's Chrome extension.",
  "type": "commonjs",
  "main": "dist/lib.js",
  "types": "dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "require": "./dist/lib.js",
      "default": "./dist/lib.js"
    }
  },
  "bin": {
    "mcp-chrome-bridge": "./dist/cli.js",
    "chrome-mcp-bridge": "./dist/cli.js",
    "mcp-chrome-stdio": "./dist/mcp/mcp-server-stdio.js"
  },
  "scripts": {
    "dev": "nodemon --watch src --ext ts,js,json --ignore dist/ --exec \"npm run build && npm run register:dev\"",
    "build": "node src/scripts/build.js",
    "test": "jest",
    "test:coverage": "cross-env JEST_COVERAGE=1 jest",
    "test:watch": "jest --watch",
    "lint": "eslint 'src/**/*.{js,ts}'",
    "lint:fix": "eslint 'src/**/*.{js,ts}' --fix",
    "format": "prettier --write 'src/**/*.{js,ts,json}'",
    "register:dev": "node dist/scripts/register-dev.js",
    "postinstall": "node -e \"const fs=require('fs');const path=require('path');const cp=require('child_process');const script=path.join(process.cwd(),'dist','scripts','postinstall.js');if(fs.existsSync(script)){cp.execFileSync(process.execPath,[script],{stdio:'inherit'});}else{console.log('[mcp-chrome-bridge] dist/scripts/postinstall.js not found; skipping postinstall (workspace/dev install).');}\"",
    "prepack": "npm run build"
  },
  "files": [
    "dist",
    "!dist/node_path.txt",
    "README.md",
    "install.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "preferGlobal": true,
  "keywords": [
    "native-messaging",
    "mcp",
    "chrome",
    "chrome-extension",
    "browser",
    "fastify"
  ],
  "author": "poetrycoder",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/casterkay/ruminer-browser-agent.git",
    "directory": "app/native-server"
  },
  "bugs": {
    "url": "https://github.com/casterkay/ruminer-browser-agent/issues"
  },
  "homepage": "https://github.com/casterkay/ruminer-browser-agent/tree/master/app/native-server#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.69",
    "@fastify/cors": "^11.0.1",
    "@modelcontextprotocol/sdk": "^1.11.0",
    "@types/node-fetch": "2",
    "chalk": "^5.4.1",
    "chrome-devtools-frontend": "^1.0.1299282",
    "chrome-mcp-shared": "workspace:*",
    "commander": "^13.1.0",
    "fastify": "^5.3.2",
    "is-admin": "^4.0.0",
    "node-fetch": "2",
    "pino": "^9.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/chrome": "^0.0.318",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.3",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/parser": "^8.31.1",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^15.5.1",
    "nodemon": "^3.1.10",
    "pino-pretty": "^13.0.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.0",
    "ts-jest": "^29.3.2",
    "typescript": "^5.8.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  }
}
